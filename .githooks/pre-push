#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# pre-push — warn when pushing [fix] commits to a non-main branch.
#
# Install:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-push   # (Unix; Windows git-bash handles this)
#
# Behavior: WARN, do not block. Pressing Enter proceeds; Ctrl+C aborts.
# The idea is nudge, not obstruct — people often legitimately push fix
# commits to feature branches for CI visibility.
#
# Reference: docs/BRANCH_WORKFLOW.md §5
# ──────────────────────────────────────────────────────────────
set -e

MAIN_BRANCH="${MAIN_BRANCH:-main}"

# Read stdin: <local-ref> <local-sha> <remote-ref> <remote-sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip deletions
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  # If pushing to main directly, no warning needed — that's the goal.
  remote_branch="${remote_ref#refs/heads/}"
  [ "$remote_branch" = "$MAIN_BRANCH" ] && continue

  # Determine the range of new commits
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — compare against main
    if git rev-parse --verify --quiet "origin/${MAIN_BRANCH}" > /dev/null; then
      range="origin/${MAIN_BRANCH}..${local_sha}"
    else
      range="${MAIN_BRANCH}..${local_sha}"
    fi
  else
    range="${remote_sha}..${local_sha}"
  fi

  fix_count=$(git log --oneline "$range" 2>/dev/null \
    | grep -cE '^[0-9a-f]+ (\[fix\]|fix(\([^)]+\))?:|hotfix:)' \
    || true)

  if [ "$fix_count" -gt 0 ]; then
    printf '\n\033[1;33m⚠ Pushing %d [fix] commits to non-main branch: %s\033[0m\n' \
      "$fix_count" "$remote_branch"
    printf '   Remember to create a PR to %s or cherry-pick.\n' "$MAIN_BRANCH"
    printf '   See docs/BRANCH_WORKFLOW.md §4 for the standard flow.\n\n'

    # Give the user a beat to think. Non-interactive (CI) skips.
    if [ -t 0 ]; then
      printf '   Press Enter to continue, Ctrl+C to abort: '
      read -r _ < /dev/tty || true
    fi
  fi
done

exit 0
